    "sport", "dport", "ltime",
    "sttl", "ct_state_ttl", "dttl",
    "sbytes", "dbytes", "smean", "dmean", "rate",
    "dur", "spkts", "dpkts",
    "sloss", "dloss",
    "sload", "dload",
    "swin", "dwin",
